# Server-only — never use VITE_ prefix (would leak to the browser).

# OKLink creation-info (deployer) via GET /api/oklink/creation-info
OKLINK_API_KEY=

# —— A2MCP paid verify (POST /api/agent/verify/paid) ——
# Receiving wallet for x402 USDC on X Layer (same 0x address you control)
X402_PAY_TO=
# Alias accepted:
# X402_WALLET_ADDRESS=

# Display price (default $0.01)
X402_PRICE_USD=0.01

# Settlement network — X Layer by default (NOT Base)
# Use: xlayer | eip155:196 | xlayer-testnet | eip155:1952
X402_NETWORK=xlayer

# USDC on X Layer (token contract + EIP-712 domain)
X402_ASSET=0x74b7f16337b8972027f6196a17a631ac6de26d22
X402_ASSET_NAME=USD Coin
X402_ASSET_VERSION=2

# Official OKX facilitator (URL is public configuration, not a secret)
X402_FACILITATOR_URL=https://web3.okx.com/api/v6/pay/x402

# OKX Developer Portal Payment API credentials. Store as Worker secrets.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Local only: accept any non-empty PAYMENT-SIGNATURE / X-PAYMENT (never in production)
X402_DEV_BYPASS=0
