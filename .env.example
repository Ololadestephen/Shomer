# Server-only — never use VITE_ prefix (would leak to the browser).

# OKLink creation-info (deployer) via GET /api/oklink/creation-info
OKLINK_API_KEY=

# —— A2MCP paid verify (POST /api/agent/verify/paid) ——
# Receiving wallet for x402 USDC on X Layer (same 0x address you control)
X402_PAY_TO=
# Alias accepted:
# X402_WALLET_ADDRESS=

# Display price (default $0.01)
X402_PRICE_USD=0.01

# Settlement network — X Layer by default (NOT Base)
# Use: xlayer | eip155:196 | xlayer-testnet | eip155:1952
X402_NETWORK=xlayer

# Asset label (USDC on X Layer)
X402_ASSET=USDC

# Optional facilitator for real settlement verification (must support X Layer if used)
# X402_FACILITATOR_URL=

# Local only: accept any non-empty PAYMENT-SIGNATURE / X-PAYMENT (never in production)
X402_DEV_BYPASS=0
